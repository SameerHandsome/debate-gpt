# Copy this file to .env at the repo root and fill in your real keys.
# .env is gitignored; .env.example is committed so the structure stays clear.

# --- LLM provider keys ---
GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-...

# --- Debate config ---
# Default debate rounds (2-5). Per PRD §3.3.
MAX_ROUNDS=3

# --- Day 3: Neon Postgres (asyncpg DSN) ---
# Get this from the Neon dashboard: postgresql://USER:PASS@HOST/DBNAME?sslmode=require
DATABASE_URL=postgresql://USER:PASS@HOST/DBNAME?sslmode=require

# --- Day 3: Upstash Redis REST ---
# Get URL + token from the Upstash console (REST API section).
UPSTASH_REDIS_REST_URL=https://YOUR-UPSTASH-ENDPOINT.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN

# --- Day 3: CORS (comma-separated origins) ---
# "*" allows all; for production, lock to your frontend origin.
CORS_ORIGINS=http://localhost:5173

# --- Day 3: Loki observability sink (optional) ---
# Set LOKI_ENABLED=true and LOKI_URL to ship logs to Grafana Loki.
# Leave LOKI_ENABLED=false (or unset) to fall back to console + JSON file only.
LOKI_ENABLED=false
LOKI_URL=

# --- Day 3: log level ---
LOG_LEVEL=INFO
